DATABASE_URL=postgresql://postgres:password@localhost:5432/credits_db
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@example.com

# ---------- Customization ----------
# Schedule shape — application-layer only; widening these for real also
# requires a database migration to match the CHECK constraints. See
# app/config.py and database/README.md before changing these in production.
PERIODS_PER_DAY=5
DAY_ORDER_MAX=6

# Branding
APP_NAME=FAFLOW
PRIMARY_COLOR=#4f46e5

# Deployment
FRONTEND_ORIGIN=["http://localhost:5173"]
MAX_SECONDARY_ADMINS=3

